# =============================================================================
# HoneyAegis Configuration
# Copy this file to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
HONEYAEGIS_ENV=production
HONEYAEGIS_DEBUG=false
HONEYAEGIS_SECRET_KEY=change-me-to-a-random-64-char-string
HONEYAEGIS_TIMEZONE=UTC
HONEYAEGIS_HOSTNAME=honeyaegis

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=honeyaegis
POSTGRES_USER=honeyaegis
POSTGRES_PASSWORD=change-me-postgres-password

# TimescaleDB (enabled by default in full profile)
TIMESCALEDB_ENABLED=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Default admin user (created on first run)
ADMIN_EMAIL=admin@honeyaegis.local
ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Cowrie SSH/Telnet Honeypot
# -----------------------------------------------------------------------------
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223
COWRIE_HOSTNAME=svr04
COWRIE_LOG_PATH=/var/log/cowrie

# External ports (what attackers connect to)
COWRIE_EXTERNAL_SSH_PORT=22
COWRIE_EXTERNAL_TELNET_PORT=23

# -----------------------------------------------------------------------------
# OpenCanary (full profile)
# -----------------------------------------------------------------------------
OPENCANARY_ENABLED=false

# -----------------------------------------------------------------------------
# Dionaea - Malware Capture (full profile)
# -----------------------------------------------------------------------------
DIONAEA_ENABLED=false

# -----------------------------------------------------------------------------
# Beelzebub - LLM Honeypot (full profile)
# -----------------------------------------------------------------------------
BEELZEBUB_ENABLED=false

# -----------------------------------------------------------------------------
# Ollama - Local AI (full profile)
# -----------------------------------------------------------------------------
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=phi3:mini
OLLAMA_ENABLED=false

# -----------------------------------------------------------------------------
# Vector (Log Shipper)
# -----------------------------------------------------------------------------
VECTOR_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# GeoIP Enrichment
# -----------------------------------------------------------------------------
GEOIP_DB_PATH=/data/geoip/GeoLite2-City.mmdb
MAXMIND_LICENSE_KEY=

# AbuseIPDB (optional enrichment)
ABUSEIPDB_API_KEY=

# -----------------------------------------------------------------------------
# Notifications (Apprise)
# -----------------------------------------------------------------------------
# Comma-separated Apprise URLs
# Examples:
#   mailto://user:pass@gmail.com
#   slack://TokenA/TokenB/TokenC
#   discord://webhook_id/webhook_token
#   ntfy://ntfy.sh/honeyaegis
APPRISE_URLS=

# Alert thresholds
ALERT_ON_NEW_SESSION=true
ALERT_ON_MALWARE_CAPTURE=true
ALERT_COOLDOWN_MINUTES=5

# -----------------------------------------------------------------------------
# Traefik Reverse Proxy (full profile)
# -----------------------------------------------------------------------------
TRAEFIK_ENABLED=false
TRAEFIK_DASHBOARD=false
TRAEFIK_ACME_EMAIL=admin@example.com
DOMAIN=honeyaegis.local

# -----------------------------------------------------------------------------
# Prometheus + Grafana (full profile)
# -----------------------------------------------------------------------------
GRAFANA_ENABLED=false
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# -----------------------------------------------------------------------------
# Fleet / Multi-Sensor
# -----------------------------------------------------------------------------
SENSOR_ID=sensor-01
SENSOR_NAME=Primary Sensor
FLEET_MODE=standalone
# Set to 'hub' for central console or 'sensor' for remote sensor

# -----------------------------------------------------------------------------
# SaaS Relay (full profile)
# -----------------------------------------------------------------------------
RELAY_ENABLED=false
# Hub URL for sensor-only deployments:
# HONEYAEGIS_HUB_URL=http://your-hub-ip:8000

# -----------------------------------------------------------------------------
# Stripe Billing (optional, for hosted/enterprise tiers)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Usage Analytics (opt-in, privacy-first)
# -----------------------------------------------------------------------------
ANALYTICS_ENABLED=false

# -----------------------------------------------------------------------------
# Threat Intelligence Feeds (optional)
# -----------------------------------------------------------------------------
# AlienVault OTX (free API key: https://otx.alienvault.com)
OTX_API_KEY=
# MISP instance (self-hosted)
MISP_URL=
MISP_API_KEY=
MISP_VERIFY_SSL=true
# VirusTotal (free API key: https://www.virustotal.com)
VIRUSTOTAL_API_KEY=

# -----------------------------------------------------------------------------
# Malware Sandbox (optional, full profile)
# -----------------------------------------------------------------------------
# Cuckoo/CAPE sandbox API URL
CUCKOO_API_URL=
