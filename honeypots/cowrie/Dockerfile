FROM cowrie/cowrie:latest

# HoneyAegis Cowrie Honeypot
# Based on the official Cowrie image with custom configuration

LABEL maintainer="HoneyAegis <https://github.com/honeyaegis>"
LABEL description="Cowrie SSH/Telnet honeypot for HoneyAegis"

# Cowrie runs as non-root by default in the official image
# Configuration is mounted via docker-compose volumes

EXPOSE 2222 2223
